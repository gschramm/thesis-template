  \else%
    \PackageWarning{thumbs}{\string\thumbsoverviewback\space%
      used in a one-sided document.\MessageBreak%
      Maybe you want to use \string\thumbsoverview\space instead?\MessageBreak%
      Code}%
  \fi%
  \ifthumbs@righttoleft\thumbsoverviewprint{#1}{r}%
  \else\thumbsoverviewprint{#1}{l}%
  \fi%
  }

\newcommand{\thumbsoverviewverso}[1]{%
  \if@twoside%
  \else%
    \PackageWarning{thumbs}{\string\thumbsoverviewverso\space%
      used in a one-sided document.\MessageBreak%
      Maybe you want to use \string\thumbsoverview\space instead?\MessageBreak%
      Code}%
  \fi%
  \ifthumbs@righttoleft\thumbsoverviewprint{#1}{d}%
  \else\thumbsoverviewprint{#1}{v}%
  \fi%
  }

